# =============================================================================
# ANOR-MATRX - Unified Runtime Configuration
# =============================================================================
# This file is the single source of truth for the entire application.
# DO NOT hardcode URLs, ports, or models in components - use runtime.ts instead.

# -----------------------------------------------------------------------------
# Application Core
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=ANOR-MATRX
APP_WORKSPACE=C:\Users\ANOR\3D Objects\AGNT\anor-matrx
APP_DATA_DIR=C:\Users\ANOR\.anor-matrx

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
BACKEND_PORT=3002
FRONTEND_PORT=3000
PYTHON_ROOM_PORT=3210
TERMINAL_BRIDGE_PORT=3211

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
# NOTE: On Windows, Ollama typically runs on port 11435
OLLAMA_HOST=127.0.0.1:11435
OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MODELS_DIR=C:\AI\Models\Ollama

# Model assignments per surface
OLLAMA_MODEL=gemma3:latest
OLLAMA_CODE_MODEL=qwen2.5-coder:3b
OLLAMA_PYTHON_MODEL=deepseek-coder:latest
OLLAMA_AGENT_MODEL=deepseek-coder:latest

# -----------------------------------------------------------------------------
# OpenClaw Configuration
# -----------------------------------------------------------------------------
OPENCLAW_PROVIDER=ollama
OPENCLAW_BASE_URL=http://127.0.0.1:11435
OPENCLAW_DEFAULT_MODEL=ollama/gemma3:latest
OPENCLAW_CODE_MODEL=ollama/qwen2.5-coder:3b
OPENCLAW_PYTHON_MODEL=ollama/deepseek-coder:latest

# -----------------------------------------------------------------------------
# Skills Layers (Precedence: workspace > project-agent > personal-agent > shared)
# -----------------------------------------------------------------------------
SKILLS_SHARED_DIR=C:\Users\ANOR\.openclaw\skills
SKILLS_PERSONAL_AGENT_DIR=C:\Users\ANOR\.agents\skills
SKILLS_PROJECT_AGENT_DIR=C:\Users\ANOR\3D Objects\AGNT\anor-matrx\.agents\skills
SKILLS_WORKSPACE_DIR=C:\Users\ANOR\3D Objects\AGNT\anor-matrx\skills

# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
GITHUB_ENABLED=true
GOOGLE_DRIVE_ENABLED=true
CLOUD_SYNC_ENABLED=true

# -----------------------------------------------------------------------------
# API Keys (Get from https://aistudio.google.com/app/apikey)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=